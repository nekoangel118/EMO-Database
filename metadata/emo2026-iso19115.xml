  <!-- Identification info -->
  <gmd:identificationInfo>
    <gmd:MD_DataIdentification>

      <gmd:citation>
        <gmd:CI_Citation>
          <gmd:title>
            <gco:CharacterString>Eocene Marine Ostracod Database (EMO)</gco:CharacterString>
          </gmd:title>
          <gmd:date>
            <gmd:CI_Date>
              <gmd:date><gco:Date>2026-01-01</gco:Date></gmd:date>
              <gmd:dateType>
                <gmd:CI_DateTypeCode 
