          <gmd:keyword><gco:CharacterString>paleobiology</gco:CharacterString></gmd:keyword>
          <gmd:keyword><gco:CharacterString>taxonomy</gco:CharacterString></gmd:keyword>
          <gmd:keyword><gco:CharacterString>marine microfossils</gco:CharacterString></gmd:keyword>
